{
  "name": "english-learn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:seed": "tsx prisma/seed.ts",
    "roleplay:bridge": "python scripts/roleplay_realtime_bridge.py --port 8876",
    "roleplay:bridge:bg": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Start-Process -WindowStyle Hidden -FilePath python -ArgumentList 'scripts/roleplay_realtime_bridge.py','--port','8876' -WorkingDirectory '.'\"",
    "audio:listening": "tsx scripts/generate-listening-audio.mjs",
    "seed:listening": "tsx scripts/seed-listening-materials.mjs"
  },
  "dependencies": {
    "@prisma/client": "6.19.2",
    "@sentry/nextjs": "^10.42.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "openai": "^6.27.0",
    "posthog-js": "^1.359.0",
    "posthog-node": "^5.28.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^20.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^27.0.1",
    "magicast": "^0.3.5",
    "prisma": "6.19.2",
    "tailwindcss": "^4",
    "tsx": "^4.20.5",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
